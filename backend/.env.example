# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (Vite dev server, prod domain)
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/snapcut?retryWrites=true&w=majority

# ---------------------------------------------------------------------------
# Firebase Admin (from Firebase Console -> Project Settings -> Service Accounts
# -> Generate new private key). Paste the values from the downloaded JSON.
# IMPORTANT: keep the \n escape sequences in the private key when pasting into
# a single-line .env value.
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Cloudinary (Dashboard -> Account Details)
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_HISTORY_FOLDER=snapcut/history

# ---------------------------------------------------------------------------
# ClipDrop (https://clipdrop.co/apis -> Remove Background API)
# ---------------------------------------------------------------------------
CLIPDROP_API_KEY=your_clipdrop_api_key
CLIPDROP_ENDPOINT=https://clipdrop-api.co/remove-background/v1

# ---------------------------------------------------------------------------
# Paddle (Sandbox / demo). Get these from paddle.com sandbox dashboard:
# Developer Tools -> Authentication (API key) and Notifications (webhook secret).
# PADDLE_ENV = sandbox | production
# ---------------------------------------------------------------------------
PADDLE_ENV=sandbox
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_notification_webhook_secret
PADDLE_CLIENT_TOKEN=your_paddle_client_side_token
PADDLE_PRO_PRICE_ID=pri_xxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Plan limits
# ---------------------------------------------------------------------------
FREE_DAILY_LIMIT=10
